generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  admin
  trainer
  client
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
}

enum MuscleGroup {
  chest
  back
  shoulders
  biceps
  triceps
  legs
  glutes
  abs
  cardio
  full_body
  quads
  hamstrings
  calves
  forearms
  traps
  core
  abductors
  adductors
  hybrid
}

// DayOfWeek se mantiene para compatibilidad pero las rutinas ahora usan dayNumber
enum DayOfWeek {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}

// ─── Models ──────────────────────────────────────────────

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  name                String
  password            String
  role                UserRole @default(client)
  trainerId           String?  @map("trainer_id")
  avatarUrl           String?  @map("avatar_url")
  phone               String?
  dietaryGoal         String?  @map("dietary_goal") // Usado para el objetivo fitness
  weight              Float?
  height              Float?
  targetCalories      Int?     @map("target_calories")
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")

  // Perfil Avanzado (Onboarding Extendido)
  experienceLevel    String? @map("experience_level")
  equipmentAccess    String? @map("equipment_access")
  medicalConditions  String? @map("medical_conditions")
  dietaryPreferences String? @map("dietary_preferences")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  trainer User?  @relation("TrainerClients", fields: [trainerId], references: [id])
  clients User[] @relation("TrainerClients")

  meals             Meal[]
  dietChatMessages  DietChatMessage[]
  routinesAsClient  Routine[]         @relation("ClientRoutines")
  routinesAsTrainer Routine[]         @relation("TrainerRoutines")
  workoutLogs       WorkoutLog[]

  codesGenerated InvitationCode[] @relation("TrainerCodes")
  usedCode       InvitationCode?  @relation("UsedByUser")
  dailyTasks     DailyTask[]
  taskLogs       TaskLog[]
  waterLogs      WaterLog[]

  @@index([trainerId, isActive])
  @@map("users")
}

model InvitationCode {
  id           String   @id @default(uuid())
  code         String   @unique
  trainerId    String   @map("trainer_id")
  isUsed       Boolean  @default(false) @map("is_used")
  usedByUserId String?  @unique @map("used_by_user_id")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relaciones
  trainer User  @relation("TrainerCodes", fields: [trainerId], references: [id])
  usedBy  User? @relation("UsedByUser", fields: [usedByUserId], references: [id])

  @@map("invitation_codes")
}

model Meal {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  name             String
  description      String
  imageUrl         String?  @map("image_url")
  imageUrls        String[] @default([]) @map("image_urls")
  mealType         MealType @map("meal_type")
  // Información nutricional (aplanada)
  calories         Float    @default(0)
  protein          Float    @default(0)
  carbs            Float    @default(0)
  fat              Float    @default(0)
  fiber            Float    @default(0)
  sugar            Float    @default(0)
  foods            String[] @default([])
  recommendation   String?
  goalRating       String?  @map("goal_rating")
  isRecommendation Boolean  @default(false) @map("is_recommendation")
  recommendedBy    String?  @map("recommended_by")
  date             DateTime @default(now())
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relaciones
  user User @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@index([date])
  @@map("meals")
}

model DietChatMessage {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  role      String // "user" o "ai"
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("diet_chat_messages")
}

model Routine {
  id          String   @id @default(uuid())
  name        String // "RUTINA SEMANA 1 - 4"
  description String   @default("")
  trainerId   String   @map("trainer_id")
  clientId    String   @map("client_id")
  weekCount   Int      @default(4) @map("week_count") // Número de semanas (default 4)
  isFavorable Boolean? @map("is_favorable")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relaciones
  trainer     User         @relation("TrainerRoutines", fields: [trainerId], references: [id])
  client      User         @relation("ClientRoutines", fields: [clientId], references: [id])
  routineDays RoutineDay[]

  @@index([trainerId, isActive])
  @@index([clientId, isActive])
  @@map("routines")
}

// Cada día dentro de una rutina (Día 1 Cuádriceps, Día 2 Espalda, etc.)
model RoutineDay {
  id          String   @id @default(uuid())
  routineId   String   @map("routine_id")
  dayNumber   Int      @map("day_number") // 1, 2, 3, 4, 5...
  focusArea   String   @map("focus_area") // "Cuádriceps", "Espalda y Hombros", etc.
  isRestDay   Boolean  @default(false) @map("is_rest_day") // Día 4: Descanso total
  restDayNote String?  @map("rest_day_note") // "DÍA CLAVE. El crecimiento ocurre aquí"
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relaciones
  routine   Routine    @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercises Exercise[]

  @@unique([routineId, dayNumber])
  @@map("routine_days")
}

model Exercise {
  id           String      @id @default(uuid())
  routineDayId String      @map("routine_day_id")
  name         String
  muscleGroup  MuscleGroup @map("muscle_group")
  sets         Int
  reps         String // "8-12", "10-15", "Fallo técnico"
  restSeconds  Int         @default(60) @map("rest_seconds")
  observations String? // "180'' descanso", "Por pierna", "En polea"
  videoUrl     String?     @map("video_url")
  order        Int         @default(0)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  // Relaciones
  routineDay  RoutineDay   @relation(fields: [routineDayId], references: [id], onDelete: Cascade)
  workoutLogs WorkoutLog[]

  @@map("exercises")
}

// Registro semanal: el cliente trackea peso, reps y observaciones por ejercicio por semana
model WorkoutLog {
  id           String    @id @default(uuid())
  exerciseId   String    @map("exercise_id")
  userId       String    @map("user_id") // El cliente
  weekNumber   Int       @map("week_number") // 1, 2, 3, 4
  weight       Float? // Peso usado (kg) — resumen / peso principal
  repsDone     String?   @map("reps_done") // Reps logradas — resumen
  observations String? // Notas del cliente
  setsData     Json?     @map("sets_data") // [{set:1, weight:40, reps:12, completed:true}, ...]
  duration     Int? // Duración total en segundos
  completedAt  DateTime? @map("completed_at") // Cuándo se marcó como completado
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relaciones
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([exerciseId, userId, weekNumber])
  @@map("workout_logs")
}

model ExerciseDictionary {
  id          String      @id @default(uuid())
  name        String      @unique
  muscleGroup MuscleGroup @map("muscle_group")
  videoUrl    String?     @map("video_url")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("exercise_dictionary")
}

// ─── Daily Tasks (Checklist de tareas diarias) ──────────

model DailyTask {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String   // "Desayunar", "Entrenar", "Almorzar", etc.
  icon      String   @default("✅") // Emoji
  order     Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs TaskLog[]

  @@index([userId, isActive])
  @@map("daily_tasks")
}

model TaskLog {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  date      String   // "2026-03-06" — fecha local del usuario
  completed Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  task DailyTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, date])
  @@index([userId, date])
  @@map("task_logs")
}

// ─── Water Tracking ─────────────────────────────────────

model WaterLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  date      String   // "2026-03-06"
  amount    Int      @default(0) // number of glasses
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("water_logs")
}

